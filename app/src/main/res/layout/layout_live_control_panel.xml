<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#CC000000"
    android:gravity="center">

    <TextView
        android:id="@+id/control_program_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:text="节目名称" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/control_rewind_10"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="-10s"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="20dp" />

        <TextView
            android:id="@+id/control_play_pause"
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:text="暂停"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/control_forward_10"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="+10s"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:background="#33FFFFFF"
            android:layout_marginStart="20dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp">

        <SeekBar
            android:id="@+id/control_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="0"
            android:max="100" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_current_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/control_total_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/control_speed_btn"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center"
        android:text="倍速 1.0x"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="#33FFFFFF" />

</LinearLayout>
